<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="commonWrapContent.textView">
        <item name="android:fontFamily">serif</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="commonWrapContent.button">
        <item name="fontFamily">serif</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/black</item>
        <item name="android:textSize">18sp</item>
    </style>
    <style name="commonMPWC.textField">
        <item name="android:layout_marginStart">32dp</item>
        <item name="android:layout_marginEnd">32dp</item>
        <item name="fontFamily">serif</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/black</item>
        <item name="backgroundTint">@color/black</item>
        <item name="android:textSize">20sp</item>
    </style>
    <style name="commonMPWC.toolbar">
        <item name="android:background">@color/black</item>
        <item name="title">@string/app_name</item>
        <item name="titleTextColor">@color/white</item>
    </style>
    <style name="commonMatchParent.navigationView">
        <item name="android:layout_gravity">start</item>
        <item name="android:background">@color/white</item>
        <item name="subheaderColor">@color/black</item>
        <item name="itemTextColor">@color/black</item>
    </style>
</resources>